# 复制为 .env 并填写。所有变量都是可选的——没有 key 时应用走启发式回退。
#
# ============================================================
# 推荐配置 1：DeepSeek（国内速度快、便宜）
# 注意：DeepSeek 2026 已升级到 V4 系列，旧的 deepseek-chat / deepseek-reasoner 会被弃用
# ============================================================
OPENAI_API_KEY=sk-你的DeepSeekKey
OPENAI_BASE_URL=https://api.deepseek.com

# ---- 模型分级（自动按调用场景切换）----
# Fast：日常聚合（板块新闻总结、情绪打分），调用次数多
OPENAI_MODEL_FAST=deepseek-v4-flash
# Deep：关键决策（追踪股操作建议、新股 / 打新申购建议、TACO 影响），调用少但要准
OPENAI_MODEL_DEEP=deepseek-v4-pro
# 如果想全用便宜模型省钱，可把 DEEP 也改成 deepseek-v4-flash
# 如果想全用深度模型，把 FAST 改成 deepseek-v4-pro（费用约高 6 倍）

# 兼容旧字段（如果只设这个，fast/deep 都会用它）
# OPENAI_MODEL=deepseek-v4-flash

# ============================================================
# 推荐配置 2：OpenAI 官方
# ============================================================
# OPENAI_API_KEY=sk-你的OpenAIKey
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# 推荐配置 3：Moonshot Kimi
# ============================================================
# OPENAI_API_KEY=sk-你的MoonshotKey
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# ============================================================
# 调度
# ============================================================
DAILY_UPDATE_HHMM=06:30
TIMEZONE=Asia/Shanghai

# ============================================================
# 数据库
# ============================================================
DB_PATH=app/storage/stocks.db
